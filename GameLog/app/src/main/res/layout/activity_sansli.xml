<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="30dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=" GÜNÜN OYUNU "
        android:textColor="#FFD700"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="30dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="200dp"
        android:layout_height="280dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1F1F1F">

        <ImageView
            android:id="@+id/ivSansliResim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvSansliAd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Oyun Seçiliyor..."
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tvSansliPlatform"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textColor="#888888"
        android:textSize="16sp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnTekrarDene"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="TEKRAR DENE 🎲"
        android:backgroundTint="#333333"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnSansliKapat"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="KAPAT"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"/>

</LinearLayout>