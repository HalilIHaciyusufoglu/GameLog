<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#1F1F1F"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="0dp"> <ImageView
        android:id="@+id/ivOyunKapak"
        android:layout_width="90dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:background="#2C2C2C"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvListeAd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="The Witcher 3"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvListePlatform"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PC"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvListePuan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5/5 ⭐"
                    android:textColor="#FFD700"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvListeDurum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oynuyorum"
                android:textColor="#00BFFF"
                android:textSize="12sp"
                android:layout_marginTop="8dp"
                android:background="@drawable/rounded_background"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>