<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnGeri"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#AAAAAA"/>

        <androidx.cardview.widget.CardView
            android:layout_width="160dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#2C2C2C">
            <ImageView
                android:id="@+id/ivDetayResim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvDetayAd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oyun Adı"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <RatingBar
            android:id="@+id/ratingDetay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:progressTint="#FFD700"
            android:isIndicator="true"
            android:stepSize="0.5"
            android:numStars="5"
            android:layout_marginTop="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="@drawable/rounded_background"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDetayPlatform"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Platform: PC"
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetayEkleyen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ekleyen: Admin"
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDetayDurum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Durum: Oynuyorum"
                android:textColor="#00BFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HİKAYE &amp; KONU"
            android:textColor="#00BFFF"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDetayHikaye"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oyunun hikayesi burada yer alacak..."
            android:textColor="#DDDDDD"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp"/>

        <LinearLayout
            android:id="@+id/layoutButonlar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="30dp">

            <Button
                android:id="@+id/btnListemeEkle"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="BU OYUNU LİSTEME EKLE (+)"
                android:backgroundTint="#00BFFF"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/layoutKisiselBilgiler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnDuzenle"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="DÜZENLE / PUAN VER ⭐"
                    android:backgroundTint="#FFD700"
                    android:textColor="#121212"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnSil"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="OYUNU SİL 🗑️"
                    android:backgroundTint="#D32F2F"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>